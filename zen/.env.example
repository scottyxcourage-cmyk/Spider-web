# Copy this file to .env and fill in real values. Never commit .env to git.

# Port the server listens on (pxxl.run usually injects PORT automatically)
PORT=3000

# Secret used to sign session JWTs - make this a long random string
JWT_SECRET=change-this-to-a-long-random-secret

# --- Free SMTP settings ---
# Use any free SMTP provider: Gmail (with an App Password), Brevo (Sendinblue),
# Mailtrap, Zoho Mail, Outlook, etc.
#
# Example for Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=your-16-char-app-password   <- NOT your normal Gmail password.
#                                            Create one at https://myaccount.google.com/apppasswords
#
# Example for Brevo (300 free emails/day):
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your-brevo-login@smtp-brevo.com
#   SMTP_PASS=your-brevo-smtp-key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-app-password

# The "From" header on outgoing emails
EMAIL_FROM=SpiderCode <youraddress@gmail.com>

# The public URL of this deployed app (used to build verification/reset links in emails)
# e.g. https://spiderhub.pxxl.run
PUBLIC_URL=http://localhost:3000
