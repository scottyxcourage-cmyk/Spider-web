# Copy this file to .env and fill in real values. Never commit .env to git.

# Port the server listens on (pxxl.run usually injects PORT automatically)
PORT=3000

# Secret used to sign session JWTs - make this a long random string
JWT_SECRET=change-this-to-a-long-random-secret

# --- Resend (email API) ---
# Sign up free at https://resend.com (100 emails/day, 3000/month free)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address on outgoing emails.
# On a brand-new Resend account you can use the sandbox sender below with no setup:
#   EMAIL_FROM=Spider Hub <onboarding@resend.dev>
# To send from your own domain/address, verify a domain at https://resend.com/domains
# first, then use something like:
#   EMAIL_FROM=Spider Hub <noreply@yourdomain.com>
EMAIL_FROM=Spider Hub <onboarding@resend.dev>

# The public URL of this deployed app (used to build verification/reset links in emails)
# e.g. https://spiderhub.pxxl.run
PUBLIC_URL=http://localhost:3000
